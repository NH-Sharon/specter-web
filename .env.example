# ──────────────────────────────────────────────────
# Specter Technologies — Environment Variables
# Copy to .env and fill in actual values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────

# Database
POSTGRES_DB=specterdb
POSTGRES_USER=specter
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Spring Boot
SPRING_PROFILES_ACTIVE=production
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_256BIT
CORS_ALLOWED_ORIGINS=https://spectertech.com

# Email (for contact form)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@spectertech.com
MAIL_PASSWORD=CHANGE_ME

# CI/CD Variables (set in GitLab Settings > Variables)
# CI_REGISTRY_USER=registry_user
# CI_REGISTRY_PASSWORD=registry_password
# STAGING_HOST=staging.spectertech.com
# STAGING_USER=deploy
# STAGING_SSH_KEY=<private_key>
# PROD_HOST=spectertech.com
# PROD_USER=deploy
# PROD_SSH_KEY=<private_key>
